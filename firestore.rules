rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isFriendRequestParticipant() {
      return isSignedIn()
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    }

    function keepsFriendRequestPair() {
      return request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toUid == resource.data.toUid;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/savedRounds/{roundId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /users/{userId}/savedGames/{gameId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    match /publicUsers/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId)
        && request.resource.data.uid == userId;
      allow delete: if isOwner(userId);
    }

    match /friendRequests/{requestId} {
      allow get: if isSignedIn();
      allow list: if isFriendRequestParticipant();

      allow create: if isSignedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.toUid != request.auth.uid
        && request.resource.data.status == "pending";

      allow update: if isSignedIn()
        && keepsFriendRequestPair()
        && (
          (
            resource.data.status == "pending"
            && resource.data.toUid == request.auth.uid
            && request.resource.data.status in ["accepted", "rejected"]
          )
          ||
          (
            resource.data.status == "pending"
            && resource.data.fromUid == request.auth.uid
            && request.resource.data.status == "cancelled"
          )
          ||
          (
            resource.data.status == "accepted"
            && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid)
            && request.resource.data.status == "removed"
          )
        );

      allow delete: if false;
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    match /merchOrders/{orderId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    match /clubhouseQuickPollVotes/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update, delete: if false;
    }

    match /siteData/quickPoll {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /siteData/quickPoll/votes/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update, delete: if false;
    }

    match /siteData/adminConfig/adminUsers/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
